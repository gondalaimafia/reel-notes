# Source
INSTAGRAM_SAVED_URL=https://www.instagram.com/saved/all-posts/
CHROME_USER_DATA_DIR=
CHROME_PROFILE_DIR=Default
HEADLESS=false
DISCOVERY_SCROLLS=25
PACE_MS=2500

# Output
# Use an Obsidian folder, Logseq pages folder, Dendron vault folder, or any normal directory.
OUTPUT_DIR=notes
OUTPUT_ADAPTER=obsidian
OUTPUT_INDEX_FILE=Social Video Notes Index.md
NOTE_FILENAME_MODE=topic

# Run size
RUN_LIMIT=3
BACKLOG_LIMIT=100
WEEKLY_LIMIT=25

# Media capture
YTDLP_COMMAND=py -m yt_dlp
YTDLP_COOKIES_FROM_BROWSER=chrome
MEDIA_RETENTION=delete_after_transcription

# Models
# TRANSCRIPTION_PROVIDER can be local, openai, or none.
# SUMMARY_PROVIDER can be local, openai, or none.
TRANSCRIPTION_PROVIDER=local
SUMMARY_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
LOCAL_WHISPER_MODEL=data/models/ggml-tiny.en.bin

# Parallel workers
AUDIO_CONCURRENCY=3
CAPTURE_CONCURRENCY=2
ENRICH_CONCURRENCY=3
ENRICH_LIMIT=3000
